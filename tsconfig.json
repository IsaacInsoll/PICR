{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "outDir": "dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": [
      "ES2021.String"
    ],
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["backend/**/*.ts"],
  "exclude": ["node_modules"]
}
