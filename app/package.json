{
  "name": "app",
  "version": "1.0.6",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "release:version": "node ../node_modules/release-it/bin/release-it.js --config package.json"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@georstat/react-native-image-cache": "^3.1.0",
    "@gorhom/bottom-sheet": "^5",
    "@hookform/resolvers": "^5.0.1",
    "@kolking/react-native-avatar": "^2.1.5",
    "@kolking/react-native-rating": "^1.4.1",
    "@likashefqet/react-native-image-zoom": "^4.3.0",
    "@react-native-menu/menu": "2.0.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@rnrepo/expo-config-plugin": "^0.1.0-beta.0",
    "@shopify/flash-list": "2.0.2",
    "@urql/exchange-graphcache": "^7.2.3",
    "expo": "^55.0.9",
    "expo-application": "~55.0.10",
    "expo-blur": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-media-library": "~55.0.10",
    "expo-notifications": "~55.0.14",
    "expo-router": "~55.0.8",
    "expo-screen-orientation": "~55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-video": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "jotai": "2.17.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.56.4",
    "react-native": "0.83.4",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-file-access": "^3.1.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-ios-context-menu": "3.2",
    "react-native-ios-utilities": "5.2",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-segmented-control-2": "^2.1.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "urql": "^4.2.2",
    "zeego": "^3.0.6",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^24.12.0",
    "@types/react": "~19.2.10",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~55.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "3.5.3",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "zeego": {
      "@react-native-menu/menu": "2.0.0",
      "react-native-ios-context-menu": "3.2",
      "react-native-ios-utilities": "5.2"
    }
  },
  "release-it": {
    "npm": {
      "publish": false
    },
    "github": false,
    "hooks": {
      "after:git:release": [
        "git push origin master",
        "git push origin app-v${version}"
      ]
    },
    "git": {
      "requireBranch": "master",
      "commitMessage": "🚀📱 App release ${version}",
      "tagName": "app-v${version}",
      "commit": true,
      "tag": true,
      "push": false
    }
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "private": true
}
